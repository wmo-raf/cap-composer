#: capcomposer/src/capcomposer/capeditor/blocks.py:136
#: capcomposer/src/capcomposer/capeditor/models.py:228
msgid "Reference Alert"
msgstr "Tahadhari ya Marejeleo"

#: capcomposer/src/capcomposer/capeditor/blocks.py:137
msgid "Earlier alert referenced by this alert"
msgstr "Tahadhari ya awali iliyorejelewa na tahadhari hii"

#: capcomposer/src/capcomposer/capeditor/blocks.py:141
#: capcomposer/src/capcomposer/capeditor/models.py:233
msgid "Incident"
msgstr "Tukio"

#: capcomposer/src/capcomposer/capeditor/blocks.py:141
msgid "Referent incident to this alert message"
msgstr "Tukio linalorejelewa kwa ujumbe huu wa tahadhari"

#: capcomposer/src/capcomposer/capeditor/blocks.py:146
#: capcomposer/src/capcomposer/capeditor/blocks.py:173
#: capcomposer/src/capcomposer/capeditor/blocks.py:503
msgid "Value"
msgstr "Thamani"

#: capcomposer/src/capcomposer/capeditor/blocks.py:151
msgid "Shelter - Take shelter in place or per instruction"
msgstr "Makazi - Pata makazi mahali au kwa maagizo"

#: capcomposer/src/capcomposer/capeditor/blocks.py:152
msgid "Evacuate - Relocate as instructed in the instruction"
msgstr "Ondoka - Hamisha kama ilivyoelekezwa katika maagizo"

#: capcomposer/src/capcomposer/capeditor/blocks.py:153
msgid "Prepare - Relocate as instructed in the instruction"
msgstr "Jitayarishe - Hamisha kama ilivyoelekezwa katika maagizo"

#: capcomposer/src/capcomposer/capeditor/blocks.py:154
msgid "Execute - Execute a pre-planned activity identified in instruction"
msgstr ""
"Tekeleza - Tekeleza shughuli iliyopangwa mapema iliyotambuliwa katika "
"maagizo"

#: capcomposer/src/capcomposer/capeditor/blocks.py:155
msgid "Avoid - Avoid the subject event as per the instruction"
msgstr "Epuka - Epuka tukio la somo kulingana na maagizo"

#: capcomposer/src/capcomposer/capeditor/blocks.py:156
msgid "Monitor - Attend to information sources as described in instruction"
msgstr ""
"Monitor - Hudhuria vyanzo vya habari kama ilivyofafanuliwa katika maagizo"

#: capcomposer/src/capcomposer/capeditor/blocks.py:157
msgid ""
"Assess - Evaluate the information in this message - DONT USE FOR PUBLIC "
"ALERTS"
msgstr ""
"Tathmini - Tathmini taarifa katika ujumbe huu - USITUMIE KWA TAARIFA KWA "
"UMMA"

#: capcomposer/src/capcomposer/capeditor/blocks.py:158
msgid ""
"All Clear - The subject event no longer poses a threat or concern and any "
"follow on action is described in instruction"
msgstr ""
"Yote Wazi - Tukio la somo halileti tishio au wasiwasi tena na ufuatiliaji "
"wowote wa hatua unaelezwa katika maagizo"

#: capcomposer/src/capcomposer/capeditor/blocks.py:160
msgid "No action recommended"
msgstr "Hakuna hatua inayopendekezwa"

#: capcomposer/src/capcomposer/capeditor/blocks.py:163
msgid "Response type"
msgstr "Aina ya majibu"

#: capcomposer/src/capcomposer/capeditor/blocks.py:164
msgid ""
"The code denoting the type of action recommended for the target audience"
msgstr ""
"Msimbo unaoashiria aina ya kitendo kinachopendekezwa kwa hadhira lengwa"

#: capcomposer/src/capcomposer/capeditor/blocks.py:169
msgid "Value Name"
msgstr "Jina la Thamani"

#: capcomposer/src/capcomposer/capeditor/blocks.py:171
msgid ""
"User-assigned string designating the domain of the code. Acronyms SHOULD be "
"represented in all capital letters without periods (e.g., SAME, FIPS, ZIP"
msgstr ""
"Mfuatano uliokabidhiwa na mtumiaji unaobainisha kikoa cha msimbo. Vifupisho "
"VINAPASWA kuwakilishwa katika herufi kubwa zote zisizo na viashirio (k.m., "
"SAME, FIPS, ZIP"

#: capcomposer/src/capcomposer/capeditor/blocks.py:174
msgid "A string (which may represent a number) denoting the value itself"
msgstr "Mfuatano (unaoweza kuwakilisha nambari) unaoashiria thamani yenyewe"

#: capcomposer/src/capcomposer/capeditor/blocks.py:177
msgid "Geographically-based code to describe a message target area"
msgstr "Msimbo unaotegemea kijiografia kuelezea eneo lengwa la ujumbe"

#: capcomposer/src/capcomposer/capeditor/blocks.py:233
msgid "Level 0"
msgstr "Kiwango cha 0"

#: capcomposer/src/capcomposer/capeditor/blocks.py:234
msgid "Level 1"
msgstr "Kiwango cha 1"

#: capcomposer/src/capcomposer/capeditor/blocks.py:235
msgid "Level 2"
msgstr "Kiwango cha 2"

#: capcomposer/src/capcomposer/capeditor/blocks.py:236
msgid "Level 3"
msgstr "Kiwango cha 3"

#: capcomposer/src/capcomposer/capeditor/blocks.py:239
#: capcomposer/src/capcomposer/capeditor/blocks.py:299
#: capcomposer/src/capcomposer/capeditor/blocks.py:377
msgid "Affected areas / Regions"
msgstr "Maeneo / Mikoa iliyoathirika"

#: capcomposer/src/capcomposer/capeditor/blocks.py:241
#: capcomposer/src/capcomposer/capeditor/blocks.py:301
#: capcomposer/src/capcomposer/capeditor/blocks.py:379
msgid "The text describing the affected area of the alert message"
msgstr "Maandishi yanayoelezea eneo lililoathiriwa la ujumbe wa tahadhari"

#: capcomposer/src/capcomposer/capeditor/blocks.py:242
msgid "Administrative Level"
msgstr "Kiwango cha Utawala"

#: capcomposer/src/capcomposer/capeditor/blocks.py:243
msgid "Boundary"
msgstr "Mpaka"

#: capcomposer/src/capcomposer/capeditor/blocks.py:244
#: capcomposer/src/capcomposer/capeditor/blocks.py:304
msgid ""
"The paired values of points defining a polygon that delineates the affected "
"area of the alert message"
msgstr ""
"Thamani zilizooanishwa za vidokezo vinavyofafanua poligoni ambayo hufafanua "
"eneo lililoathiriwa la ujumbe wa tahadhari."

#: capcomposer/src/capcomposer/capeditor/blocks.py:247
#: capcomposer/src/capcomposer/capeditor/blocks.py:306
#: capcomposer/src/capcomposer/capeditor/blocks.py:381
#: capcomposer/src/capcomposer/capeditor/blocks.py:430
msgid "Altitude"
msgstr "Mwinuko"

#: capcomposer/src/capcomposer/capeditor/blocks.py:248
#: capcomposer/src/capcomposer/capeditor/blocks.py:307
#: capcomposer/src/capcomposer/capeditor/blocks.py:382
#: capcomposer/src/capcomposer/capeditor/blocks.py:431
msgid ""
"The specific or minimum altitude of the affected area of the alert message"
msgstr ""
"Urefu mahususi au wa chini kabisa wa eneo lililoathiriwa la ujumbe wa arifa"

#: capcomposer/src/capcomposer/capeditor/blocks.py:250
#: capcomposer/src/capcomposer/capeditor/blocks.py:309
#: capcomposer/src/capcomposer/capeditor/blocks.py:384
#: capcomposer/src/capcomposer/capeditor/blocks.py:433
msgid "Ceiling"
msgstr "Dari"

#: capcomposer/src/capcomposer/capeditor/blocks.py:251
#: capcomposer/src/capcomposer/capeditor/blocks.py:310
#: capcomposer/src/capcomposer/capeditor/blocks.py:385
#: capcomposer/src/capcomposer/capeditor/blocks.py:434
msgid ""
"The maximum altitude of the affected area of the alert message.MUST NOT be "
"used except in combination with the altitude element. "
msgstr ""
"Upeo wa juu wa eneo lililoathiriwa la ujumbe wa tahadhari.LAZIMA USITUMIKE "
"isipokuwa pamoja na kipengele cha mwinuko."

#: capcomposer/src/capcomposer/capeditor/blocks.py:254
#: capcomposer/src/capcomposer/capeditor/blocks.py:312
#: capcomposer/src/capcomposer/capeditor/blocks.py:387
#: capcomposer/src/capcomposer/capeditor/blocks.py:436
msgid "Geocode"
msgstr "Msimbo wa kijiografia"

#: capcomposer/src/capcomposer/capeditor/blocks.py:302
msgid "Polygon"
msgstr "Poligoni"

#: capcomposer/src/capcomposer/capeditor/blocks.py:380
#: capcomposer/src/capcomposer/capeditor/blocks.py:693
msgid "Circle"
msgstr "Mduara"

#: capcomposer/src/capcomposer/capeditor/blocks.py:380
msgid "Drag the marker to change position"
msgstr "Buruta alama ili kubadilisha nafasi"

#: capcomposer/src/capcomposer/capeditor/blocks.py:429
#: capcomposer/src/capcomposer/capeditor/cap_settings.py:73
#: capcomposer/src/capcomposer/capeditor/cap_settings.py:164
msgid "Area"
msgstr "Eneo"

#: capcomposer/src/capcomposer/capeditor/blocks.py:439
msgid "The human-readable name of the agency or authority issuing this alert."
msgstr ""
"Jina linaloweza kusomeka na binadamu la wakala au mamlaka inayotoa arifa "
"hii."

#: capcomposer/src/capcomposer/capeditor/blocks.py:440
msgid ""
"The text describing the contact for follow-up and confirmation of the alert "
"message"
msgstr ""
"Maandishi yanayoelezea mwasiliani kwa ufuatiliaji na uthibitisho wa ujumbe "
"wa tahadhari"

#: capcomposer/src/capcomposer/capeditor/blocks.py:482
#: capcomposer/src/capcomposer/capeditor/blocks.py:491
msgid "Resource Description"
msgstr "Maelezo ya Rasilimali"

#: capcomposer/src/capcomposer/capeditor/blocks.py:483
#: capcomposer/src/capcomposer/capeditor/blocks.py:492
msgid "The text describing the type and content of the resource file"
msgstr "Maandishi yanayoelezea aina na maudhui ya faili ya rasilimali"

#: capcomposer/src/capcomposer/capeditor/blocks.py:493
msgid "External Resource Link"
msgstr "Kiungo cha Rasilimali za Nje"

#: capcomposer/src/capcomposer/capeditor/blocks.py:494
msgid ""
"Link to external resource. This can be for example a link to related "
"websites. "
msgstr ""
"Unganisha kwa rasilimali ya nje. This can be for example a link to related "
"websites."

#: capcomposer/src/capcomposer/capeditor/blocks.py:502
msgid "Name for the event code"
msgstr "Jina la msimbo wa tukio"

#: capcomposer/src/capcomposer/capeditor/blocks.py:503
msgid "Value of the event code"
msgstr "Thamani ya msimbo wa tukio"

#: capcomposer/src/capcomposer/capeditor/blocks.py:624
msgid "Immediate - Responsive action SHOULD be taken immediately"
msgstr "Papo Hapo - Hatua ya kujibu INATAKIWA ichukuliwe mara moja"

#: capcomposer/src/capcomposer/capeditor/blocks.py:625
msgid "Expected - Responsive action SHOULD be taken soon (within next hour)"
msgstr ""
"Inatarajiwa - Hatua ya kujibu LAZIMA ichukuliwe hivi karibuni (ndani ya saa "
"ijayo)"

#: capcomposer/src/capcomposer/capeditor/blocks.py:626
msgid "Future - Responsive action SHOULD be taken in the near future"
msgstr ""
"Wakati Ujao - Hatua ya kuitikia LAZIMA ichukuliwe katika siku za usoni"

#: capcomposer/src/capcomposer/capeditor/blocks.py:627
msgid "Past - Responsive action is no longer required"
msgstr "Zamani - Hatua ya kujibu haihitajiki tena"

#: capcomposer/src/capcomposer/capeditor/blocks.py:632
msgid "Extreme - Extraordinary threat to life or property"
msgstr "Uliokithiri - Tishio lisilo la kawaida kwa maisha au mali"

#: capcomposer/src/capcomposer/capeditor/blocks.py:633
msgid "Severe - Significant threat to life or property"
msgstr "Kali - Tishio kubwa kwa maisha au mali"

#: capcomposer/src/capcomposer/capeditor/blocks.py:634
msgid "Moderate - Possible threat to life or property"
msgstr "Wastani - Tishio linalowezekana kwa maisha au mali"

#: capcomposer/src/capcomposer/capeditor/blocks.py:635
msgid "Minor - Minimal to no known threat to life or property"
msgstr "Ndogo - Ndogo hadi tishio lisilojulikana kwa maisha au mali"

#: capcomposer/src/capcomposer/capeditor/blocks.py:640
msgid "Observed - Determined to have occurred or to be ongoing"
msgstr "Imezingatiwa - Imedhamiriwa kuwa imetokea au kuwa inaendelea"

#: capcomposer/src/capcomposer/capeditor/blocks.py:641
msgid "Likely - Likely (percentage > ~50%)"
msgstr "Huenda - Huenda (asilimia> ~50%)"

#: capcomposer/src/capcomposer/capeditor/blocks.py:642
msgid "Possible - Possible but not likely (percentage <= ~50%)"
msgstr "Inawezekana - Inawezekana lakini haiwezekani (asilimia <= ~50%)"

#: capcomposer/src/capcomposer/capeditor/blocks.py:643
msgid "Unlikely - Not expected to occur (percentage ~ 0)"
msgstr "Haiwezekani - Haitarajiwi kutokea (asilimia ~ 0)"

#: capcomposer/src/capcomposer/capeditor/blocks.py:647
#: capcomposer/src/capcomposer/capeditor/templates/capeditor/cap_alert_page.html:30
#: capcomposer/src/capcomposer/capeditor/templates/capeditor/cap_alert_page.html:195
msgid "Event"
msgstr "Tukio"

#: capcomposer/src/capcomposer/capeditor/blocks.py:648
msgid ""
"The text denoting the type of the subject event of the alert message. You "
"can define hazards events monitored by your institution from CAP settings"
msgstr ""
"Maandishi yanayoashiria aina ya tukio la somo la ujumbe wa tahadhari. "
"Unaweza kufafanua matukio ya hatari yanayofuatiliwa na taasisi yako kutoka "
"kwa mipangilio ya CAP"

#: capcomposer/src/capcomposer/capeditor/blocks.py:651
#: capcomposer/src/capcomposer/capeditor/cap_settings.py:77
msgid "Language"
msgstr "Lugha"

#: capcomposer/src/capcomposer/capeditor/blocks.py:652
#, fuzzy
#| msgid "The code denoting the language of the alert message"
msgid ""
"The code denoting the language of the alert message.If not selected, 'en-US'"
" will be used as default"
msgstr ""
"Msimbo unaoashiria lugha ya ujumbe wa arifa. Ikiwa hautachaguliwa, 'en-US' "
"itatumika kama chaguo-msingi."

#: capcomposer/src/capcomposer/capeditor/blocks.py:654
msgid "Urgency"
msgstr "Uharaka"

#: capcomposer/src/capcomposer/capeditor/blocks.py:655
msgid ""
"The code denoting the urgency of the subject event of the alert message"
msgstr "Msimbo unaoashiria uharaka wa tukio la somo la ujumbe wa tahadhari"

#: capcomposer/src/capcomposer/capeditor/blocks.py:657
#: capcomposer/src/capcomposer/capeditor/templates/capeditor/cap_alert_page.html:104
msgid "Severity"
msgstr "Ukali"

#: capcomposer/src/capcomposer/capeditor/blocks.py:658
msgid ""
"The code denoting the severity of the subject event of the alert message"
msgstr "Msimbo unaoashiria ukali wa tukio la somo la ujumbe wa tahadhari"

#: capcomposer/src/capcomposer/capeditor/blocks.py:660
#: capcomposer/src/capcomposer/capeditor/templates/capeditor/cap_alert_page.html:113
msgid "Certainty"
msgstr "Uhakika"

#: capcomposer/src/capcomposer/capeditor/blocks.py:661
msgid ""
"The code denoting the certainty of the subject event of the alert message"
msgstr "Msimbo unaoashiria uhakika wa tukio la somo la ujumbe wa tahadhari"

#: capcomposer/src/capcomposer/capeditor/blocks.py:663
msgid "Headline"
msgstr "Kichwa cha habari"

#: capcomposer/src/capcomposer/capeditor/blocks.py:664
msgid ""
"The text headline of the alert message. Make it direct and actionable as "
"possible while remaining short"
msgstr ""
"Kichwa cha maandishi cha ujumbe wa tahadhari. Ifanye moja kwa moja na iweze "
"kutekelezeka iwezekanavyo huku ikisalia kuwa fupi"

#: capcomposer/src/capcomposer/capeditor/blocks.py:666
msgid "Description"
msgstr "Maelezo"

#: capcomposer/src/capcomposer/capeditor/blocks.py:668
msgid ""
"The text describing the subject event of the alert message. An extended "
"description of the hazard or event that occasioned this message"
msgstr ""
"Maandishi yanayoelezea tukio la somo la ujumbe wa tahadhari. Maelezo "
"yaliyopanuliwa ya hatari au tukio lililosababisha ujumbe huu"

#: capcomposer/src/capcomposer/capeditor/blocks.py:670
msgid "Instruction"
msgstr "Maagizo"

#: capcomposer/src/capcomposer/capeditor/blocks.py:671
msgid ""
"The text describing the recommended action to be taken by recipients of the "
"alert message"
msgstr ""
"Maandishi yanayoelezea hatua iliyopendekezwa kuchukuliwa na wapokeaji wa "
"ujumbe wa arifa"

#: capcomposer/src/capcomposer/capeditor/blocks.py:673
#: capcomposer/src/capcomposer/capeditor/templates/capeditor/cap_alert_page.html:56
msgid "Effective"
msgstr "Ufanisi"

#: capcomposer/src/capcomposer/capeditor/blocks.py:674
msgid ""
"The effective time of the information of the alert message. If not set, the "
"sent date will be used"
msgstr ""
"Wakati mzuri wa taarifa ya ujumbe wa tahadhari. Ikiwa haijawekwa, tarehe "
"iliyotumwa itatumika"

#: capcomposer/src/capcomposer/capeditor/blocks.py:676
#: capcomposer/src/capcomposer/capeditor/templates/capeditor/cap_alert_page.html:72
msgid "Onset"
msgstr "Mwanzo"

#: capcomposer/src/capcomposer/capeditor/blocks.py:677
msgid ""
"The expected time of the beginning of the subject event of the alert message"
msgstr "Muda unaotarajiwa wa mwanzo wa tukio la somo la ujumbe wa tahadhari"

#: capcomposer/src/capcomposer/capeditor/blocks.py:679
#: capcomposer/src/capcomposer/capeditor/templates/capeditor/cap_alert_page.html:81
msgid "Expires"
msgstr "Muda wake unaisha"

#: capcomposer/src/capcomposer/capeditor/blocks.py:680
msgid ""
"The expiry time of the information of the alert message. If not set, each "
"recipient is free to set its own policy as to when the message is no longer "
"in effect."
msgstr ""
"Muda wa mwisho wa taarifa ya ujumbe wa arifa. Ikiwa haijawekwa, kila "
"mpokeaji yuko huru kuweka sera yake mwenyewe kuhusu ni lini ujumbe haufanyi "
"kazi tena."

#: capcomposer/src/capcomposer/capeditor/blocks.py:683
msgid "Response Types"
msgstr "Aina za Majibu"

#: capcomposer/src/capcomposer/capeditor/blocks.py:685
msgid "Sender name"
msgstr "Jina la mtumaji"

#: capcomposer/src/capcomposer/capeditor/blocks.py:687
#: capcomposer/src/capcomposer/capeditor/cap_settings.py:43
msgid "Contact"
msgstr "Wasiliana"

#: capcomposer/src/capcomposer/capeditor/blocks.py:688
msgid "Audience"
msgstr "Hadhira"

#: capcomposer/src/capcomposer/capeditor/blocks.py:689
msgid "The text describing the intended audience of the alert message"
msgstr "Maandishi yanayoelezea hadhira iliyokusudiwa ya ujumbe wa tahadhari"

#: capcomposer/src/capcomposer/capeditor/blocks.py:691
msgid "Admin Boundary"
msgstr "Mpaka wa Utawala"

#: capcomposer/src/capcomposer/capeditor/blocks.py:692
msgid "Draw Polygon"
msgstr "Chora Polygon"

#: capcomposer/src/capcomposer/capeditor/blocks.py:694
#: capcomposer/src/capcomposer/capeditor/cap_settings.py:167
msgid "Predefined Area"
msgstr "Eneo Lililoainishwa"

#: capcomposer/src/capcomposer/capeditor/blocks.py:695
msgid "Alert Area"
msgstr "Eneo la Tahadhari"

#: capcomposer/src/capcomposer/capeditor/blocks.py:695
msgid "Admin Boundary, Polygon, Circle, or Predefined area"
msgstr "Mpaka wa Msimamizi, Poligoni, Mduara, au eneo Lililobainishwa Awali"

#: capcomposer/src/capcomposer/capeditor/blocks.py:700
msgid "Resources"
msgstr "Rasilimali"

#: capcomposer/src/capcomposer/capeditor/blocks.py:700
msgid ""
"Additional file with supplemental information related to this alert "
"information"
msgstr ""
"Faili ya ziada iliyo na maelezo ya ziada yanayohusiana na taarifa hii ya "
"arifa"

#: capcomposer/src/capcomposer/capeditor/blocks.py:703
msgid "Parameter"
msgstr "Kigezo"

#: capcomposer/src/capcomposer/capeditor/blocks.py:703
msgid "Parameters"
msgstr "Vigezo"

#: capcomposer/src/capcomposer/capeditor/blocks.py:723
msgid "The expiry time of the alert should be greater than the effective time"
msgstr "Muda wa kuisha kwa arifa unapaswa kuwa mkubwa kuliko wakati unaofaa"

#: capcomposer/src/capcomposer/capeditor/blocks.py:728
msgid "The expiry time of the alert should be greater than the onset time"
msgstr "Muda wa kuisha kwa arifa unapaswa kuwa mkubwa kuliko wakati wa kuanza"

#: capcomposer/src/capcomposer/capeditor/blocks.py:735
msgid "Contact Detail"
msgstr "Maelezo ya Mawasiliano"

#: capcomposer/src/capcomposer/capeditor/cap_settings.py:29
msgid "CAP Sender Email"
